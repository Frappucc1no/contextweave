{
  "version": 1,
  "required_files": [
    "config.json",
    "state.json",
    "context_brief.md",
    "rolling_summary.md"
  ],
  "optional_files": [
    "update_protocol.md"
  ],
  "required_directories": [
    "daily_logs"
  ],
  "managed_directories": [
    "daily_logs/archive",
    "companion",
    "companion/recovery",
    "companion/recovery/proposals",
    "companion/recovery/review_log",
    "companion/recovery/archive"
  ],
  "dynamic_file_rules": [
    {
      "base_dir": "daily_logs",
      "kind": "iso_daily_log"
    },
    {
      "base_dir": "daily_logs/archive",
      "kind": "iso_daily_log"
    },
    {
      "base_dir": "companion/recovery/proposals",
      "kind": "recovery_proposal"
    },
    {
      "base_dir": "companion/recovery/review_log",
      "kind": "review_record"
    },
    {
      "base_dir": "companion/recovery/archive",
      "kind": "recovery_proposal"
    },
    {
      "base_dir": "companion/recovery/archive",
      "kind": "review_record"
    }
  ]
}
